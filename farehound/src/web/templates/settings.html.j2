{% extends "base.html.j2" %}
{% block title %}Preferences · FareHound{% endblock %}
{% block crumb %}Preferences{% endblock %}
{% block body_attrs %}data-back="true"{% endblock %}

{% block content %}
  <h1 class="display-sm" style="margin-top: 8px;">Preferences</h1>
  <p class="metadata">How FareHound calculates your real cost.</p>

  <section class="section">
    <div class="section-label"><span>Baggage needs</span></div>
    <div class="radio-group" data-name="baggage_needs">
      {% for opt in baggage_options %}
      <label class="radio-row{% if opt.value == settings.baggage_needs %} is-selected{% endif %}" data-value="{{ opt.value }}">
        <span class="dot"></span>
        <span class="label">{{ opt.label }}</span>
        <span class="desc">{{ opt.desc }}</span>
      </label>
      {% endfor %}
    </div>
  </section>

  <section class="section">
    <div class="section-label">
      <span>Airports &amp; transport</span>
      <span class="meta">tap a row to edit</span>
    </div>

    <div class="airport-actions">
      <button class="btn-link" id="add-airport-btn">+ add airport</button>
      <button class="btn-link" id="suggest-airports-btn">Suggest closest to home</button>
    </div>

    {% for ap in settings.airports %}
    <article class="airport-card" data-airport="{{ ap.code }}">
      <header class="airport-card-head">
        <span class="code">{{ ap.code }}</span>
        <span class="name">{{ ap.name }}</span>
        {% if ap.is_primary %}<span class="badge">primary</span>{% endif %}
      </header>

      <div class="modes-list">
        {% for m in ap.modes %}
        <div class="mode-row{% if not m.enabled %} is-disabled{% endif %}{% if m.mode == ap.override_mode %} is-override{% endif %}"
             data-mode="{{ m.mode }}"
             data-cost="{{ m.cost_eur or '' }}"
             data-time="{{ m.time_min or '' }}"
             data-parking="{{ m.parking_cost_per_day_eur or '' }}"
             data-enabled="{{ '1' if m.enabled else '0' }}"
             data-source="{{ m.source or '' }}"
             data-confidence="{{ m.confidence or '' }}"
             data-label="{{ m.label or '' }}">
          <span class="mode-name">{{ m.label or m.mode }}</span>
          <span class="mode-cost">{% if m.cost_eur is not none %}<span class="currency">€</span>{{ '%.0f' | format(m.cost_eur) }}{% if m.cost_scales_with_pax %}/pp{% endif %}{% else %}—{% endif %}</span>
          <span class="mode-time">{{ m.time_label or '—' }}</span>
          {% if m.parking_cost_per_day_eur %}<span class="mode-parking">parking <span class="currency">€</span>{{ '%.0f' | format(m.parking_cost_per_day_eur) }}/day</span>{% endif %}
          {% if m.confidence == 'low' or m.confidence == 'medium' %}<span class="mode-confidence" title="estimate — please confirm">estimate</span>{% endif %}
        </div>
        {% else %}
        <p class="empty-modes">No transport options yet.</p>
        {% endfor %}
      </div>

      <footer class="airport-card-foot">
        <button class="btn-link" data-action="add-mode" data-airport="{{ ap.code }}">+ add mode</button>
        {% if not ap.is_primary %}
        <button class="btn-link danger" data-action="delete-airport" data-airport="{{ ap.code }}">remove airport</button>
        {% endif %}
        {% if ap.modes %}
        <div class="override-control">
          <label>Always use:
            <select data-action="set-override" data-airport="{{ ap.code }}">
              <option value="">cheapest (auto)</option>
              {% for m in ap.modes if m.enabled %}
              <option value="{{ m.mode }}"{% if m.mode == ap.override_mode %} selected{% endif %}>{{ m.label or m.mode }}</option>
              {% endfor %}
            </select>
          </label>
        </div>
        {% endif %}
      </footer>
    </article>
    {% else %}
    <p class="footnote" style="font-family: var(--sans); color: var(--text-faint); font-size: 12px; margin-top: 12px;">
      No airports configured yet. Message me in chat to add your home airport.
    </p>
    {% endfor %}

    <p class="footnote" style="font-family: var(--sans); color: var(--text-faint); font-size: 11px; margin-top: 12px;">
      FareHound picks the cheapest mode per trip based on party size and duration. Tap any row to edit cost/time/parking. Set "Always use" to override the choice.
    </p>
  </section>

  <section class="section">
    <div class="section-label"><span>Quiet hours</span></div>
    <div class="field-row">
      <span class="label">No alerts between</span>
      <input type="time" id="quiet-from" value="{{ settings.quiet_from or '22:00' }}" />
      <span class="between">and</span>
      <input type="time" id="quiet-to" value="{{ settings.quiet_to or '07:00' }}" />
    </div>
  </section>

  <section class="section">
    <div class="section-label"><span>Daily digest</span></div>
    <div class="field-row">
      <span class="label">Send at</span>
      <input type="time" id="digest-time" value="{{ settings.digest_time or '08:00' }}" />
    </div>
    <div class="field-row">
      <span class="label">Skipped this week</span>
      <span class="value">{{ settings.digest_skip_count_7d or 0 }} of last 7 days</span>
    </div>
  </section>

  <section class="section">
    <div class="section-label"><span>Connected</span></div>
    <div class="field-row">
      <span class="label">Telegram</span>
      <span class="value">{{ settings.telegram_label }}</span>
    </div>
    <div class="field-row">
      <span class="label">FareHound version</span>
      <span class="value">{{ settings.version }}</span>
    </div>
  </section>

  <!-- Edit dialog (hidden by default; populated when user taps a mode row) -->
  <dialog id="mode-edit-dialog" class="mode-edit-dialog">
    <form id="mode-edit-form">
      <h2 id="mode-edit-title">Edit transport</h2>
      <input type="hidden" id="edit-airport" />
      <input type="hidden" id="edit-mode-canonical" />
      <label>Mode
        <select id="edit-mode-name">
          <option value="drive">drive (per car)</option>
          <option value="taxi">taxi (per car, ≤4 pax)</option>
          <option value="train">train (per person)</option>
          <option value="bus">bus (per person)</option>
          <option value="other">other</option>
        </select>
      </label>
      <label>Label (optional)
        <input type="text" id="edit-label" placeholder="e.g. ride from family" maxlength="40" />
      </label>
      <label>Cost (€, one-way)
        <input type="number" id="edit-cost" step="0.50" min="0" />
        <small id="cost-hint" class="field-hint">drive/taxi: cost for the whole party. train/bus: cost per person.</small>
      </label>
      <label>Time (minutes)
        <input type="number" id="edit-time" min="0" max="600" />
      </label>
      <label>Parking €/day (drive only)
        <input type="number" id="edit-parking" step="0.50" min="0" />
      </label>
      <label class="checkbox-row">
        <input type="checkbox" id="edit-enabled" />
        Enabled (uncheck to exclude this mode)
      </label>
      <div class="dialog-actions">
        <button type="button" id="edit-cancel">Cancel</button>
        <button type="button" id="edit-delete" class="danger">Delete</button>
        <button type="submit" id="edit-save">Save</button>
      </div>
    </form>
  </dialog>
{% endblock %}

{% block scripts %}
<script>
  // Existing baggage-needs + quiet-hours + digest-time handlers
  async function patchSettings(body) {
    const headers = { "content-type": "application/json" };
    const initData = window.Telegram?.WebApp?.initData;
    if (initData) headers["x-telegram-init-data"] = initData;
    const resp = await fetch("/api/settings", { method: "PATCH", headers, body: JSON.stringify(body) });
    if (!resp.ok) {
      const msg = (await resp.json().catch(() => ({}))).detail || `HTTP ${resp.status}`;
      throw new Error(msg);
    }
  }

  document.querySelectorAll(".radio-group").forEach((group) => {
    const name = group.dataset.name;
    group.querySelectorAll(".radio-row").forEach((row) => {
      row.addEventListener("click", async () => {
        group.querySelectorAll(".radio-row").forEach((r) => r.classList.remove("is-selected"));
        row.classList.add("is-selected");
        try {
          await patchSettings({ [name]: row.dataset.value });
          window.Telegram?.WebApp?.HapticFeedback?.selectionChanged?.();
        } catch (err) { console.warn("settings patch failed", err); }
      });
    });
  });

  ["quiet-from", "quiet-to", "digest-time"].forEach((id) => {
    const input = document.getElementById(id);
    if (!input) return;
    input.addEventListener("change", async () => {
      try { await patchSettings({ [id.replace("-", "_")]: input.value }); }
      catch (err) { console.warn("settings patch failed", err); }
    });
  });

  // ----- R9 ITEM-053: airport mode edit dialog -----
  const dialog = document.getElementById("mode-edit-dialog");
  const form = document.getElementById("mode-edit-form");

  function showToast(msg) {
    if (window.Telegram?.WebApp?.showAlert) {
      window.Telegram.WebApp.showAlert(msg);
    } else {
      console.log("[toast]", msg);
    }
  }

  async function api(method, path, body) {
    const headers = { "content-type": "application/json" };
    const initData = window.Telegram?.WebApp?.initData;
    if (initData) headers["x-telegram-init-data"] = initData;
    const resp = await fetch(path, { method, headers, body: body ? JSON.stringify(body) : null });
    if (!resp.ok) {
      const msg = (await resp.json().catch(() => ({}))).detail || `HTTP ${resp.status}`;
      throw new Error(msg);
    }
    return resp.status === 204 ? null : await resp.json();
  }

  function openEditDialog(airport, modeRow) {
    document.getElementById("edit-airport").value = airport;
    if (modeRow) {
      document.getElementById("mode-edit-title").textContent = `Edit ${modeRow.dataset.mode} for ${airport}`;
      document.getElementById("edit-mode-canonical").value = modeRow.dataset.mode;
      document.getElementById("edit-mode-name").value = modeRow.dataset.mode;
      document.getElementById("edit-mode-name").disabled = true;
      document.getElementById("edit-cost").value = modeRow.dataset.cost || "";
      document.getElementById("edit-time").value = modeRow.dataset.time || "";
      document.getElementById("edit-parking").value = modeRow.dataset.parking || "";
      document.getElementById("edit-enabled").checked = modeRow.dataset.enabled === "1";
      document.getElementById("edit-delete").style.display = "";
    } else {
      document.getElementById("mode-edit-title").textContent = `Add transport for ${airport}`;
      document.getElementById("edit-mode-canonical").value = "";
      document.getElementById("edit-mode-name").disabled = false;
      document.getElementById("edit-mode-name").value = "drive";
      document.getElementById("edit-cost").value = "";
      document.getElementById("edit-time").value = "";
      document.getElementById("edit-parking").value = "";
      document.getElementById("edit-enabled").checked = true;
      document.getElementById("edit-delete").style.display = "none";
    }
    document.getElementById("edit-label").value = modeRow?.dataset?.label || "";
    if (typeof dialog.showModal === "function") dialog.showModal();
    else dialog.setAttribute("open", "");
  }

  document.querySelectorAll(".mode-row").forEach((row) => {
    row.addEventListener("click", () => {
      const card = row.closest(".airport-card");
      openEditDialog(card.dataset.airport, row);
    });
  });

  document.querySelectorAll('[data-action="add-mode"]').forEach((btn) => {
    btn.addEventListener("click", () => openEditDialog(btn.dataset.airport, null));
  });

  document.getElementById("edit-cancel").addEventListener("click", () => {
    if (typeof dialog.close === "function") dialog.close();
    else dialog.removeAttribute("open");
  });

  document.getElementById("edit-delete").addEventListener("click", async () => {
    const airport = document.getElementById("edit-airport").value;
    const mode = document.getElementById("edit-mode-canonical").value;
    if (!confirm(`Delete ${mode} from ${airport}?`)) return;
    try {
      await api("DELETE", `/api/airports/${airport}/options/${mode}`);
      window.Telegram?.WebApp?.HapticFeedback?.notificationOccurred?.("success");
      window.location.reload();
    } catch (err) { showToast(`Couldn't delete: ${err.message}`); }
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const airport = document.getElementById("edit-airport").value;
    const canonical = document.getElementById("edit-mode-canonical").value;
    const newMode = document.getElementById("edit-mode-name").value;
    const body = {
      mode: newMode,
      cost_eur: parseFloat(document.getElementById("edit-cost").value || "0"),
      time_min: parseInt(document.getElementById("edit-time").value || "0", 10) || null,
      parking_cost_per_day_eur: parseFloat(document.getElementById("edit-parking").value || "0") || 0,
      enabled: document.getElementById("edit-enabled").checked,
      label: document.getElementById("edit-label").value,
    };
    try {
      if (canonical) {
        await api("PUT", `/api/airports/${airport}/options/${canonical}`, body);
      } else {
        await api("POST", `/api/airports/${airport}/options`, body);
      }
      window.Telegram?.WebApp?.HapticFeedback?.notificationOccurred?.("success");
      window.location.reload();
    } catch (err) { showToast(`Couldn't save: ${err.message}`); }
  });

  document.querySelectorAll('[data-action="set-override"]').forEach((sel) => {
    sel.addEventListener("change", async () => {
      const airport = sel.dataset.airport;
      const mode = sel.value || null;
      try {
        await api("PUT", `/api/airports/${airport}/override`, { mode });
        window.Telegram?.WebApp?.HapticFeedback?.notificationOccurred?.("success");
      } catch (err) { showToast(`Couldn't save: ${err.message}`); }
    });
  });

  // ----- v0.11.3: add airport / suggest closest / remove airport -----

  async function addAirportByCode(code) {
    try {
      const res = await api("POST", "/api/airports", { code });
      const modes = (res.modes_added || []).join(", ") || "0 modes auto-filled";
      showToast(`Added ${res.code} (${res.name}). ${modes}.`);
      window.location.reload();
    } catch (err) { showToast(`Couldn't add ${code}: ${err.message}`); }
  }

  document.getElementById("add-airport-btn")?.addEventListener("click", async () => {
    const code = (prompt("IATA code (3 letters) of the airport to add:") || "").trim().toUpperCase();
    if (!code) return;
    if (!/^[A-Z]{3}$/.test(code)) { showToast("Must be 3 letters."); return; }
    await addAirportByCode(code);
  });

  document.getElementById("suggest-airports-btn")?.addEventListener("click", async () => {
    let res;
    try {
      res = await api("GET", "/api/airports/suggest?limit=5");
    } catch (err) { showToast(`Couldn't suggest: ${err.message}`); return; }
    if (!res.candidates?.length) { showToast("No more nearby airports to add."); return; }
    const lines = res.candidates.map((c, i) => `${i + 1}. ${c.iata} — ${c.name} (${c.distance_km} km)`).join("\n");
    const ok = confirm(`Closest airports to ${res.home_code}:\n\n${lines}\n\nAdd all ${res.candidates.length}?`);
    if (!ok) return;
    for (const c of res.candidates) {
      try { await api("POST", "/api/airports", { code: c.iata }); }
      catch (err) { /* keep going */ }
    }
    window.location.reload();
  });

  document.querySelectorAll('[data-action="delete-airport"]').forEach((btn) => {
    btn.addEventListener("click", async () => {
      const airport = btn.dataset.airport;
      if (!confirm(`Remove ${airport} entirely? All modes for this airport will be deleted.`)) return;
      try {
        await api("DELETE", `/api/airports/${airport}`);
        window.location.reload();
      } catch (err) { showToast(`Couldn't remove ${airport}: ${err.message}`); }
    });
  });
</script>
{% endblock %}
