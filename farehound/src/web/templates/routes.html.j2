{% extends "base.html.j2" %}
{% block title %}Routes · FareHound{% endblock %}
{% block crumb %}Routes{% endblock %}
{% block body_attrs %}data-back="false"{% endblock %}

{% block content %}
  <p class="routes-count">
    {{ summary.monitored }} monitored
    {% if summary.snoozed %} · {{ summary.snoozed }} snoozed{% endif %}
    {% if summary.last_poll_label %} · last poll {{ summary.last_poll_label }}{% endif %}
  </p>

  <!-- Add-a-trip CTA — closes the Mini App and sends the user back to chat,
       where the bot's multi-turn /trip flow handles disambiguation properly. -->
  <section class="add-trip-cta">
    <p class="add-trip-cta-lede">
      To add a trip, message the bot in chat. Try:
    </p>
    <p class="add-trip-cta-example">"Tokyo for 2 weeks in October"</p>
    <p class="add-trip-cta-lede" style="margin-top: 6px;">
      I'll ask any clarifying questions and confirm before saving.
    </p>
    <button class="action" id="add-trip-back-to-chat" type="button">← Back to chat</button>
  </section>

  <div id="routes-list">
    {% for r in routes %}
    <article class="route-card{% if r.is_snoozed %} is-snoozed{% endif %}{% if r.is_pending %} is-pending{% endif %}" data-route-id="{{ r.route_id }}">
      <div class="ordinal">{{ r.ordinal }}{% if r.is_pending %} · NEW{% endif %}</div>
      <h2 class="name"><a href="/deal/{{ r.latest_deal_id }}">{{ r.origin }} → {{ r.destination }}</a></h2>
      <div class="meta-line">{{ r.city }} · {{ r.dates_label }} · {{ r.passengers }} pax</div>

      {% if r.is_pending %}
      <div class="price-row"><span class="price pending">checking prices…</span></div>
      <div class="footnote">first poll runs on the next cycle</div>
      {% else %}
      <div class="price-row">
        <span class="price">
          <span class="currency">€</span>{{ r.current_price_pp_display }}<span class="unit">/pp</span>
        </span>
        {% if r.delta_label %}
          {% if r.is_new_low %}
            <span class="badge badge-positive">New low</span>
          {% elif r.is_snoozed %}
            <span class="badge badge-warning">Snoozed</span>
          {% else %}
            <span class="delta delta-positive number">{{ r.delta_label }}</span>
          {% endif %}
        {% elif r.is_snoozed %}
          <span class="badge badge-warning">Snoozed</span>
        {% endif %}
      </div>
      <div class="footnote">{{ r.footnote }}</div>
      {% endif %}

      <div class="actions">
        {% if r.is_snoozed %}
          <button class="action" data-unsnooze type="button">Resume now</button>
        {% else %}
          <button class="action" data-snooze="7" type="button">Snooze 7d</button>
          <button class="action" data-snooze="30" type="button">Snooze 30d</button>
        {% endif %}
        <button class="action danger" data-remove type="button">Remove</button>
      </div>
    </article>
    {% endfor %}
  </div>

  <section class="section">
    <p class="footnote" style="font-family: var(--sans); font-size:12px; color: var(--text-faint); margin-top: 24px;">
      SerpAPI usage: {{ summary.serpapi_used }}/{{ summary.serpapi_cap }} this month.
      {% if summary.savings_total %}Saved you €{{ summary.savings_total }} across {{ summary.savings_trip_count }} trips.{% endif %}
    </p>
  </section>
{% endblock %}

{% block scripts %}
<script>
  // The "Back to chat" CTA closes the Mini App so the user lands in chat,
  // where the bot's /trip flow handles disambiguation properly.
  document.getElementById("add-trip-back-to-chat")?.addEventListener("click", () => {
    if (window.Telegram?.WebApp?.close) {
      window.Telegram.WebApp.close();
    } else {
      alert("Open the Telegram chat with FareHound to add a trip.");
    }
  });
</script>
{% endblock %}
